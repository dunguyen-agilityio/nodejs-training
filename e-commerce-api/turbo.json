{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalEnv": [
    "NODE_ENV",
    "POSTGRES_PORT",
    "POSTGRES_PASSWORD",
    "POSTGRES_USER",
    "POSTGRES_DB",
    "POSTGRES_URL",
    "POSTGRES_HOST",
    "CLERK_PUBLISHABLE_KEY",
    "CLERK_SECRET_KEY",
    "CLERK_WEBHOOK_SIGNING_SECRET",
    "CLERK_TOKEN_TEMPLATE",
    "STRIPE_API_KEY",
    "STRIPE_WEBHOOK_SIGNING_SECRET",
    "SENDGRID_API_KEY",
    "SENDGRID_TEMPLATE_ORDER_SUCCESS",
    "SENDGRID_TEMPLATE_REGISTER_SUCCESS",
    "SENDGRID_TEMPLATE_INVOICE",
    "SENDGRID_SUPPORT_EMAIL",
    "SENDGRID_FROM_EMAIL",
    "CLIENT_BASE_URL",
    "CLIENT_LOGIN_PATH",
    "APP_NAME",
    "APP_LOGO_URL",
    "APP_YEAR",
    "API_URL",
    "NEXT_PUBLIC_API_ENDPOINT",
    "NEXT_PUBLIC_CLERK_TOKEN_TEMPLATE",
    "NEXT_PUBLIC_STRIPE_PUBLIC_KEY",
    "NEXT_PUBLIC_BASE_URL",
    "VERCEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "build/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": { "cache": false, "persistent": true },
    "test": {
      "dependsOn": ["^test"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^test:coverage"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["coverage/**"]
    }
  }
}
